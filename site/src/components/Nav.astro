---
---

<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-10 h-16 flex items-center justify-between">
    <a href="/" class="font-display font-bold text-[15px] tracking-tight text-[#f0f0f0] hover:text-accent transition-colors duration-200 glitch-hover">
      Footprint Protocol
    </a>
    <nav class="flex items-center gap-8">
      <a href="/#spec"
         class="text-[12px] text-[#555] hover:text-[#f0f0f0] transition-colors tracking-[0.1em] uppercase font-display">Spec</a>
      <a href="/#implementations"
         class="text-[12px] text-[#555] hover:text-[#f0f0f0] transition-colors tracking-[0.1em] uppercase font-display">Implementations</a>
      <a href="https://github.com/conscious-collective/footprint"
         target="_blank" rel="noopener"
         class="text-[12px] text-[#555] hover:text-[#f0f0f0] transition-colors tracking-[0.1em] uppercase font-display">GitHub</a>
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('nav')!;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      nav.style.background = 'rgba(6,6,8,0.93)';
      nav.style.backdropFilter = 'blur(16px)';
      nav.style.borderBottom = '1px solid rgba(0,229,255,0.08)';
    } else {
      nav.style.background = 'transparent';
      nav.style.backdropFilter = 'none';
      nav.style.borderBottom = '1px solid transparent';
    }
  });
</script>
